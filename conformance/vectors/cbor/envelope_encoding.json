        "auth_tag_hex": "ff00",
        "msg_id_hex": "0193a54d000070008000000000000003",
        "msg_type": "0x0100",
        "payload_hex": "01",
        "session_id_hex": null,
        "version": 1
      }
    },
    {
      "description": "SESSION_RESUME with session_id but no auth_tag",

{
  "description": "CBOR envelope encoding test vectors for cairn wire protocol. All implementations must produce byte-identical output for deterministic CBOR encoding.",
  "vectors": [
    {
      "description": "Minimal HEARTBEAT envelope: version + msg_type + msg_id + empty payload, no session_id or auth_tag",
      "expected_output": {
        "cbor_hex": "a400010119040002500193a54d0000700080000000000000010440",
        "map_entry_count": 4
      },
      "id": "envelope-minimal-heartbeat",
      "input": {
        "auth_tag_hex": null,
        "msg_id_hex": "0193a54d000070008000000000000001",
        "msg_type": "0x0400",
        "payload_hex": "",
        "session_id_hex": null,
        "version": 1
      }
    },
    {
      "description": "Full DATA_MESSAGE envelope with all 6 fields present including session_id and auth_tag",
      "expected_output": {
        "cbor_hex": "a600010119030002500193a54d000070008000000000000002035820abababababababababababababababababababababababababababababababab0444cafebabe0550deadbeefcafebabe0102030405060708",
        "map_entry_count": 6
      },
      "id": "envelope-full-data-message",
      "input": {
        "auth_tag_hex": "deadbeefcafebabe0102030405060708",
        "msg_id_hex": "0193a54d000070008000000000000002",
        "msg_type": "0x0300",
        "payload_hex": "cafebabe",
        "session_id_hex": "abababababababababababababababababababababababababababababababab",
        "version": 1
      }
    },
    {
      "description": "PAIR_REQUEST with auth_tag but no session_id",
      "expected_output": {
        "cbor_hex": "a500010119010002500193a54d0000700080000000000000030441010542ff00",
        "map_entry_count": 5
